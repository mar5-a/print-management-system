PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://postgres:postgres@localhost:5432/print_management
JWT_SECRET=replace-with-local-development-secret

# HP MFP M830 direct raw socket test printer.
PRINTER_HOST=10.22.114.241
PRINTER_PORT=9100

# First proven Windows Server printer target.
# Use the local printer/share name for the connector running on PRINTSOL-STU1.
WINDOWS_PRINT_QUEUE_TARGET=HP-M830-22-339
WINDOWS_PRINT_QUEUE_SHARE=\\PRINTSOL-STU1\HP-M830-22-339

# Main backend -> Windows connector service.
WINDOWS_PRINT_CONNECTOR_URL=http://localhost:4100
WINDOWS_PRINT_CONNECTOR_TOKEN=

# Windows connector runtime settings.
WINDOWS_CONNECTOR_PORT=4100
WINDOWS_CONNECTOR_UPLOAD_DIR=storage/windows-connector/uploads
WINDOWS_PRINT_MODE=sumatra
SUMATRA_PDF_PATH=C:\Program Files\SumatraPDF\SumatraPDF.exe
WINDOWS_PRINT_COMMAND=
WINDOWS_PRINT_TIMEOUT_MS=60000

# macOS/Linux command is usually "gs". Windows may use "gswin64c".
GHOSTSCRIPT_BIN=gs

UPLOAD_DIR=storage/uploads
CONVERTED_DIR=storage/converted
MIGRATIONS_DIR=migrations
