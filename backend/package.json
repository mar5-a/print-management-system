{
  "name": "print-management-backend",
  "version": "1.0.0",
  "description": "Print Management System Backend",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:migrate": "node --loader tsx ./src/db/migrations/run.ts",
    "db:seed": "node --loader tsx ./src/db/seed.ts",
    "test": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "pg": "^8.20.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}